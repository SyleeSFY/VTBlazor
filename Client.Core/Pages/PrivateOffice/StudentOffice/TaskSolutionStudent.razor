@page "/TaskSolutionStudent/{Id:int}"
@using Client.Core.Entities.Enums
@using Client.Core.Features
@using Client.Core.Shared
@inject HttpClient Http
@layout PrivateOfficeLayout
@inject NavigationManager Navigation
@inject IJSRuntime JS

<AuthorizeView Context="AuthContext">
    <Authorized>
        <div class="container">
            <TittleBackground JustifyContent="@JustifyContentEnum.FlexEnd" Color="006928d8" Tittle="Решение" />

             <div style="display: flex; gap: 20px;">
                <div style="">
                    <div class="EducatorCardInfo" style=" padding-left: 2vw">
                        <div class="mb-3">
                            <TittleUnderStick Tittle="@_task.Dicipline?.NameDiscipline"
                                      PaddinLeft="0"
                                      JustifyContent="JustifyContentEnum.FlexStart"
                                      FontSize="36"/>
                        </div>
                        
                        <p><span style="font-weight: 500;">Название работы:</span> @_task.TaskName</p>
                        <p><span style="font-weight: 500;">Задание:</span> @_task.TaskDescription</p>
                        <p>
                        <span style="font-weight: 500;">Файлы:</span>

                        @if (_task.Files != null && _task.Files.Any())
                        {
                            <ul class="disciplines_list">
                            @foreach (var item in _task.Files)
                            {
                                    <li>
                                        <button @onclick="() => GetFile(item.Id, item.FileName, FileType.Task)" style="color: #0a53be; border: none; background: none;">
                                            @item.FileName
                                        </button>
                                    </li>
                            }
                            </ul>
                        }
                        else
                        {
                            <span> Отсуствуют</span>
                        }

                        </p>
                        <p><span style="font-weight: 500;">Дата:</span> @_task.CreatedAt.ToString("dd.MM.yyyy")</p>
                        @if (_existingSolution.Id is not 0)
                        {
                            <p><span style="font-weight: 500;">Ваше решение:</span></p>
                        }
                    </div>
                </div>
             </div>
             
            @if (_existingSolution.Id is not 0)
            {
                <div class="existing-solution mt-2 mb-4 p-3 EducatorCardInfo" style="border-radius: 8px; border: 2px solid lightgray; width: 60%; margin-left: auto; margin-right: auto;">
                    <p><strong>Статус:</strong>
                        <span style=" padding-left: 1vw">
                            @GlobalData.GetSolutionStatus[_existingSolution.Status]
                        </span>
                    </p>
                    @if (!string.IsNullOrEmpty(_existingSolution.SolutionText))
                    {
                        <p style="margin-bottom: 0px"><strong>Текст решения:</strong></p>
                        <div class="" style="background: white; border-radius: 4px; padding-left: 1vw">
                            @_existingSolution.SolutionText
                        </div>
                    }
                    @if (_existingSolution.SolutionFiles != null && _existingSolution.SolutionFiles.Any())
                    {
                        <p class="mt-2"><strong>Прикрепленные файлы:</strong></p>
                        <ul class="disciplines_list" style="padding-left: 0px;">
                            @foreach (var file in _existingSolution.SolutionFiles)
                            {
                                <li>
                                    <button style="color: #0a53be; border: none; background: none;" @onclick="() => GetFile(file.Id, file.FileName, FileType.Solution)">
                                        @file.FileName
                                    </button>
                                </li>
                            }
                        </ul>
                    }                               
                </div>
            } 
            <div class="row justify-content-center" style="margin-top: auto; margin-bottom: auto">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-body">
                            <EditForm Model="@_taskSolution" OnValidSubmit="@HandleValidSubmit">
                               @*  <DataAnnotationsValidator />
                                <ValidationSummary class="text-danger" /> *@
                                <div class="form-group mb-3">
@*                                     <label for="taskDescription" class="form-label">Решение</label>
 *@                                    <textarea class="form-control" id="taskDescription" rows="5" placeholder="Введите описание решения" @bind="_solutionText"></textarea>
@*                                     <ValidationMessage For="@(() => _newTaskDTO.TaskDescription)" />
 *@                                </div>
                                <div class="form-group mb-3">
                                    <label for="files" class="form-label">Файлы</label>
                                    <div class="input-group">
                                        <InputFile id="files" multiple OnChange="@OnFileUpload" class="form-control" style="padding: 0.375rem 0.75rem;" />
                                        @if (_uploadedFiles.Any())
                                        {
                                            <button type="button" class="btn btn-outline-danger" @onclick="ClearFiles">
                                                <i class="bi bi-trash"></i> Очистить
                                            </button>
                                        }
                                    </div>
                                    @if (_uploadedFiles.Any())
                                    {
                                        <div class="mt-2">
                                            <strong>Выбранные файлы (@_uploadedFiles.Count):</strong>
                                            <div class="list-group mt-2">
                                                @foreach (var file in _uploadedFiles)
                                                {
                                                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                                        <span>@file.Name</span>
                                                        <div>
                                                            <span class="badge bg-secondary me-2"> @(FormatFileSize(file.Size)) </span>
                                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveFile(file)">
                                                                <i class="bi bi-x"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="form-group mt-4">
                                    <button type="submit" class="btn btn-primary me-2" style="background: #009c15"  disabled="@(_existingSolution.Id is not 0)">>
                                        Отправить
                                    </button>
                                    <button type="button" class="btn btn-light">
                                        Очистить
                                    </button>
                                </div>
                            </EditForm>
                        </div>
                    </div>
                </div>
            </div>
            <ButtonRedirect Redirect="TaskStudentTable" Text="Назад" MT="auto" />
        </div>
    </Authorized>
    <NotAuthorized>
        <p>Вы не авторизованы</p>
    </NotAuthorized>
</AuthorizeView>