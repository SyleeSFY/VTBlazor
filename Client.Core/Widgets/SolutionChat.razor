@using Client.Core.Entities.Enums
@inject IJSRuntime JS

<div class="chat-container mb-5" style="border: 1px solid #ddd; border-radius: 8px; padding: 20px;">
    <h4 style="margin-bottom: 20px;">Чат по решению</h4>
    
    <div class="messages-container" style="height: 400px; overflow-y: auto; margin-bottom: 20px; padding: 10px; background: #f9f9f9; border-radius: 4px;">
        @if (Messages == null || !Messages.Any())
        {
            <p style="color: #666; text-align: center; margin-top: 180px;">Нет сообщений</p>
        }
        else
        {
            @foreach (var message in Messages.OrderBy(m => m.SentAt))
            {
                <div class="message @(message.SenderRole == Role.educator ? "educator-message" : "student-message")"
                     style="margin-bottom: 15px; display: flex; @(message.SenderRole == Role.educator ? "justify-content: flex-end;" : "justify-content: flex-start;")">
                    <div style="max-width: 70%;">
                        <div style="padding: 10px; border-radius: 10px; @(message.SenderRole == Role.educator ? "background: #006928d8; color: white;" : "background: white; border: 1px solid #ddd;")">
                            <div style="font-size: 12px; margin-bottom: 5px; opacity: 0.8;">
                                @(message.SenderRole == Role.educator ? "Преподаватель" : "Студент")
                                • @message.SentAt.ToString("dd.MM.yyyy HH:mm")
                            </div>
                            <div>@message.MessageText</div>
                            
                            @if (message.Files != null && message.Files.Any())
                            {
                                <div style="margin-top: 10px;">
                                    @foreach (var file in message.Files)
                                    {
                                        <button style="color: @(message.SenderRole == Role.educator ? "white" : "#0a53be");
                                            background: none;
                                            border: none;
                                            text-decoration: underline;"
                                                @onclick="() => GetFile(file)">
                                            @file.FileName
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
    
    <div class="message-input">
        <textarea @bind="_newMessage"
                  @bind:event="oninput"
                  placeholder="Введите сообщение..."
                      style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; resize: vertical; min-height: 80px;">
        </textarea>
        
            <div style="display: flex; gap: 10px; margin-top: 10px; align-items: center;">
                <div class="form-group mb-3">
                                    <label for="files" class="form-label">Файлы</label>
                                    <div class="input-group">
                                        <InputFile id="files" multiple OnChange="@OnFileUpload" class="form-control" style="padding: 0.375rem 0.75rem;"/>
                                        @if (_uploadedFiles.Any())
                                        {
                                            <button type="button" class="btn btn-outline-danger" @onclick="ClearFiles">
                                                <i class="bi bi-trash"></i> Очистить
                                            </button>
                                        }
                                    </div>
                                    @if (_uploadedFiles.Any())
                                    {
                                        <div class="mt-2">
                                            <strong>Выбранные файлы (@_uploadedFiles.Count):</strong>
                                            <div class="list-group mt-2">
                                                @foreach (var file in _uploadedFiles)
                                                {
                                                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                                        <span>@file.Name</span>
                                                        <div>
                                                            <span class="badge bg-secondary me-2"> @(FormatFileSize(file.Size)) </span>
                                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveFile(file)">
                                                                <i class="bi bi-x"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
            
                <button @onclick="SendMessage"
                        disabled="@(string.IsNullOrWhiteSpace(_newMessage) && !_uploadedFiles.Any())"
                        style="margin-left: auto; padding: 8px 20px; background: #006928d8; color: white; border: none; border-radius: 4px;">
                    Отправить
                </button>
            </div>
        </div>
    </div>